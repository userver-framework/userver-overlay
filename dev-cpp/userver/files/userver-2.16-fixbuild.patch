     std::int32_t,
     std::uint32_t,
     std::int64_t,
@@ -64,6 +68,10 @@ using InsertColumnValue = std::variant<
     Timestamp,
     std::optional<std::string>,
     std::optional<bool>,
+    std::optional<std::int8_t>,
+    std::optional<std::uint8_t>,
+    std::optional<std::int16_t>,
